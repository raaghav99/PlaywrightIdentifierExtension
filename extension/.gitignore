# ============================================================
# WHITELIST APPROACH — ignore everything, allow only source files
# To add a new file to version control, add it explicitly below.
# ============================================================

# Ignore everything by default
*

# --- Allow: core extension source files ---
!.gitignore
!manifest.json
!content.js
!form.js
!ui.js
!excel.js
!panel.css
!xlsx.min.js

# --- Allow: icons folder ---
!icons/
!icons/*

# ============================================================
# Everything else (data files, reports, scratch, secrets) stays
# local and never gets pushed:
#   *.json, *.html, *.csv, *.b64, *.zip, *.txt
#   Base64 extracted Data/, docs/, node_modules/, etc.
# ============================================================
