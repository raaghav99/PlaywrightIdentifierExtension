{
  "manifest_version": 3,
  "name": "Playwright RCA Helper",
  "version": "2.6.4",
  "key": "",
  "description": "Label, analyse and export Playwright test results with RCA tracking directly from the HTML report",
  "icons": {
    "48": "icons/icon48.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "file:///*",
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*",
        "http://*/*html-report*",
        "https://*/*html-report*"
      ],
      "js": ["xlsx.min.js", "content.js", "ui.js", "form.js", "excel.js"],
      "css": ["panel.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
